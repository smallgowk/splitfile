<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.phanduy.aliexscrap.OldHomePanelController">
    <AnchorPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
                prefWidth="500.0" prefHeight="200.0">

        <children>
            <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.bottomAnchor="10"
                  AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

                <!-- Input Settings -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Input" style="-fx-font-weight: bold;"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Product File:" minWidth="85"/>
                    <TextField fx:id="productFileField" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="browseProductFile" text="Browse..."
                            onAction="#onBrowserProductFile"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Product Count:" minWidth="85" maxWidth="90"/>
                    <TextField fx:id="numOfProductField"/>
                </HBox>

                <Separator>
                    <VBox.margin>
                        <Insets top="10"/>
                    </VBox.margin>
                </Separator>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="startButton" text="Start"
                            onAction="#onStart"/>

                    <Region fx:id="leftSpacer" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" text="" style="-fx-text-fill: blue;" alignment="CENTER"/>
                    <Region fx:id="rightSpacer" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </children>
    </AnchorPane>
</VBox>


